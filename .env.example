# Required
ANTHROPIC_API_KEY=your_key_here
NTFY_CHANNEL=your_channel_name

# Optional — enables direct Truth Social Mastodon API (bypasses Google News RSS fallback)
# How to get: log into truthsocial.com in Chrome → DevTools → Network → filter /api/
#             → copy "Authorization: Bearer <token>" from any request header
TRUTH_SOCIAL_BEARER_TOKEN=

# Optional
RELEVANCE_THRESHOLD=6

# Database (optional — leave empty to use local SQLite)
# For persistent deduplication across GitHub Actions runs, set up a free Supabase project:
# 1. Go to supabase.com → New project
# 2. Settings → Database → Connection string (URI format)
# 3. Paste the connection string here
# 4. Run: python db/migrate_to_supabase.py  (migrates existing local data)
# 5. Add DATABASE_URL to GitHub Secrets (repo Settings → Secrets → Actions)
DATABASE_URL=
