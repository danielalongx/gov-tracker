# Required
ANTHROPIC_API_KEY=your_key_here
NTFY_CHANNEL=your_channel_name

# Optional — enables direct Truth Social Mastodon API (bypasses Google News RSS fallback)
# How to get: log into truthsocial.com in Chrome → DevTools → Network → filter /api/
#             → copy "Authorization: Bearer <token>" from any request header
TRUTH_SOCIAL_BEARER_TOKEN=

# Optional
RELEVANCE_THRESHOLD=6
